# ─────────────────────────────────────────────────────────────────────────────
# Local Production Configuration (.env.local.prod)
# ─────────────────────────────────────────────────────────────────────────────
# This file is used for `npm run dev:prod` or `npm run deploy:local-prod`
# Copy to .env.local.prod and customize for your environment

# REQUIRED: Domain or IP address for production access
# Examples:
#   - localhost:8443 (local machine)
#   - 192.168.1.100:8443 (network accessible)
#   - example.local:8443 (custom domain via /etc/hosts)
#   - prod.example.com:8443 (with valid DNS)
PROD_DOMAIN=localhost:8443

# Server binding - change to 0.0.0.0 to accept connections from other machines
HOST=0.0.0.0

# HTTPS Port
PORT=8443

# Relay identification
RELAY_PEER_ID=local-prod-relay
RELAY_NAME=Local Production Relay

# WebSocket relay URL (auto-constructed as wss://{PROD_DOMAIN}/ws)
RELAY_URL=

# Optional: Global relay network for cross-relay peer discovery
GLOBAL_RELAY_URL=wss://peer.ooo/ws

# TLS Configuration (HTTPS certificates)
TLS_CERT_PATH=./certs/server.crt
TLS_KEY_PATH=./certs/server.key

# Database path (local SQLite)
# For Docker: /data/db/freertc.db
# For Node.js: ./data/freertc.db
DB_PATH=./data/freertc.db

# Node environment
NODE_ENV=production

# Log level: debug, info, warn, error
LOG_LEVEL=info
