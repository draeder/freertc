# ─────────────────────────────────────────────────────────────────────────────
# FreeRTC Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local (dev), .env.local.prod (local prod), 
# or create environment-specific files as needed.

# ─── Local Development ────────────────────────────────────────────────────────
# Use for npm run dev:local (Node.js only, no Cloudflare)
HOST=127.0.0.1
PORT=8788

# ─── Local Production ────────────────────────────────────────────────────────
# REQUIRED: Domain name for local production. Can be localhost, IP, or custom domain
# Examples: localhost, 192.168.1.100, example.local
# DO NOT use without https:// in production unless on localhost
PROD_DOMAIN=localhost:8443

# Relay peer identity
RELAY_PEER_ID=local-relay

# Relay display name
RELAY_NAME=Local Relay

# Signaling relay URL (auto-constructed as wss://{PROD_DOMAIN}/ws)
# Leave blank to auto-construct, or override manually
RELAY_URL=

# Global relay for cross-relay discovery (optional)
# Set to enable connecting with peer.ooo network
GLOBAL_RELAY_URL=wss://peer.ooo/ws

# ─── TLS/HTTPS Configuration (for local production) ───────────────────────────
# Path to self-signed certificate and key (for Docker/Node production setup)
# These must be in PEM format
TLS_CERT_PATH=./certs/server.crt
TLS_KEY_PATH=./certs/server.key

# Generate self-signed cert: 
# openssl req -x509 -newkey rsa:4096 -keyout certs/server.key -out certs/server.crt -days 365 -nodes -subj "/CN=localhost"

# ─── Cloudflare Deployment ────────────────────────────────────────────────────
# Leave these blank for local deployment
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_ZONE_ID=
CF_DOMAIN=
